{
  "name": "floodgate",
  "displayName": "Floodgate",
  "version": "0.0.1",
  "description": "Chrome extension for GitHub pull requests: favicon review/checks status, watched-repo auto-open, dedup, and link tab groups.",
  "author": "GalvinGao <galvin@mewtant.io>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "jsdom": "^29.1.1",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "vitest": "^4.1.8"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "tabGroups",
      "storage",
      "alarms"
    ],
    "host_permissions": [
      "https://github.com/*",
      "https://api.github.com/*"
    ]
  }
}
